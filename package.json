{
  "name": "set-pdf-view-fork",
  "version": "0.0.9",
  "description": "Set default PDF view options in Zotero 7–9: scroll mode, scale, page layout (spread), hand tool. Fork of qiwei-ma/zotero-pdf-setHorizontal with Zotero 9 support, a Page Layout (single / two-pages) option, and fixes for stale prefs and a blank preferences pane.",
  "config": {
    "addonName": "Set PDF View (fork)",
    "addonID": "pdfsethorizontalscroll@euclpts.com",
    "addonRef": "pdfsethorizontalscroll",
    "addonInstance": "pdfsethorizontalscroll",
    "prefsPrefix": "extensions.zotero.pdfsethorizontalscroll"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ppavlidis/zotero-pdf-setHorizontal.git"
  },
  "author": "ppavlidis (fork maintainer); originally qiwei-ma",
  "bugs": {
    "url": "https://github.com/ppavlidis/zotero-pdf-setHorizontal/issues"
  },
  "homepage": "https://github.com/ppavlidis/zotero-pdf-setHorizontal#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "echo \"Error: no test specified\" && exit 1",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.0.0-1"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.3",
    "eslint": "^9.26.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.1",
    "zotero-plugin-scaffold": "^0.6.0",
    "zotero-types": "^4.0.0-beta.10"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
